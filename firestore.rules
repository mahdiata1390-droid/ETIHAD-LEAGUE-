rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.uid == "REPLACE_WITH_ADMIN_UID";
    }

    function isSignedInPlayer() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/playerLinks/$(request.auth.uid));
    }

    // تیم‌ها، بازیکنان، مسابقات و اخبار برای همه قابل خواندن است
    // اما فقط مدیر لیگ می‌تواند تغییر دهد.
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // نگاشت حساب‌های بازیکنان؛ فقط مدیر می‌نویسد،
    // هر بازیکن فقط سند خودش را می‌تواند بخواند.
    match /playerLinks/{authUid} {
      allow read: if request.auth != null && request.auth.uid == authUid;
      allow write: if isAdmin();
    }
  }
}
